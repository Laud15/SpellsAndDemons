rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------
    // SUPPORT FUNCTION
    // -------------------------------------------------------
    
    // the user that make the reuqest is auth.
    function isAuth() {
      return request.auth != null;
    }

    // the user that make the request is the owner of the doc
    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // -------------------------------------------------------
    // USERS
    // -------------------------------------------------------
    match /users/{uid} {
      // everyone who is logged can read alla profile(this is necessary for search other users)
      allow read: if isAuth();

      //Only the owner can create their own document and only with the expected fields
      allow create: if isOwner(uid) 
        && request.resource.data.keys().hasOnly(['uid', 'username', 'email', 'score', 'friends','pushSubscription', 'createdAt']);
      //Only the owner can update their profile
      // But it can't edit UID, email, and points on its own
      // (score is changed only by Cloud Functions)
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['username', 'friends','pushSubscription']);

      //nobody can delete any other user
      allow delete: if false;
    }

    // -------------------------------------------------------
    // USERNAMES
    // -------------------------------------------------------
    match /usernames/{username} {
      //everyone can read (it is used to check uniqueness during registration)
      allow read: if true;

      //Only the logged in user can reserve his username and the document must contain only his UID
      allow create: if isAuth()
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;

      //No one can change or delete an already reserved username
      allow update, delete: if false;
    }

    // -------------------------------------------------------
    // FRIENDREQUEST
    // -------------------------------------------------------

    match /friendRequests/{requestId} {

      //only who is in the request (sender or receive) can read
      allow read: if isAuth()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid)

      //an user can only create request with him as sender
      allow create: if isAuth()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['fromUid', 'fromUsername', 'toUid', 'status', 'createdAt']);

      //only the receiver can update the status
      allow update: if isAuth()
        && resource.data.toUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);

      allow delete: if false;
    }

    // -------------------------------------------------------
    // LOBBIES
    // -------------------------------------------------------
    match /lobbies/{lobbyId} {
      //onyl lobby's member and invited users can read the lobby
      allow read: if isAuth()
        && (request.auth.uid in resource.data.playerIds || request.auth.uid in resource.data.invitedIds)

      //Only a logged-in user can create a lobby must be the host and the first player
      allow create: if isAuth()
        && request.resource.data.hostId == request.auth.uid
        && request.resource.data.status == 'waiting'
        && request.resource.data.keys().hasOnly(['hostId', 'playerIds', 'players', 'invitedIds', 'status', 'createdAt']);

      //Only members or invited users can update the lobby
      //the status can be updated only by the host of the lobby
      allow update: if isAuth()
       && (
          request.auth.uid in resource.data.playerIds
          ||
           request.auth.uid in resource.data.invitedIds
          )
      && (
          (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerIds', 'players', 'invitedIds'])
            && 
            request.resource.data.playerIds.size() <= 4
          )
          ||
          (
            resource.data.hostId == request.auth.uid
            && 
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playerIds', 'players', 'hostId', 'status', 'invitedIds'])
          )
        );

      allow delete: if false;
    }

    // -------------------------------------------------------
    // GAMES
    // -------------------------------------------------------
    match /games/{gameId} {
      // Only players in the game can read the status
      allow read: if isAuth()
        && request.auth.uid in resource.data.playerIds;

      //No one can create or edit a game from the client
      //everything goes through Cloud Functions
      allow create, update, delete: if false;
    }

    // -------------------------------------------------------
    // SCROLLS 
    // -------------------------------------------------------
    match /scrolls/{scrollId} {
      //Everyone can read the catalogue
      allow read: if isAuth();

      //No one can change it from the client
      allow create, update, delete: if false;
    }

    // -------------------------------------------------------
    // STATUSES
    // -------------------------------------------------------
    match /statuses/{statusId} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }

    // -------------------------------------------------------
    // ENEMIES
    // -------------------------------------------------------
    match /enemies/{enemyId} {
      allow read: if isAuth();
      allow create, update, delete: if false;
    }

  }
}